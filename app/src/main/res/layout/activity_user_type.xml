<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout android:id="@+id/btnSighted"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/gradient_blue"
        android:clickable="true" android:focusable="true">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="طالب مبصر"
                android:textSize="26sp" android:textColor="#FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="اضغط هنا إذا كنت مبصراً"
                android:textSize="14sp" android:textColor="#CCFFFFFF"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </FrameLayout>

    <TextView android:layout_width="match_parent" android:layout_height="4dp"
        android:background="#FFFFFF"/>

    <FrameLayout android:id="@+id/btnBlind"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/gradient_dark"
        android:clickable="true" android:focusable="true">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="طالب كفيف"
                android:textSize="26sp" android:textColor="#FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="اضغط هنا إذا كنت كفيفاً"
                android:textSize="14sp" android:textColor="#B3FFFFFF"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>